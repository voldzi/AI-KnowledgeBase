# AKL LLM Gateway Service
AKL_SERVICE_NAME=llm-gateway-service
AKL_SERVICE_VERSION=dev
AKL_ENV=development
AKL_LOG_LEVEL=INFO

# disabled/mock are dev/test only.
# bearer uses AKL_SERVICE_TOKEN; oidc requires a bearer JWT.
AKL_AUTH_MODE=disabled
AKL_SERVICE_TOKEN=

# Provider routing
# Providers: mock, ollama, openai
# Default stays mock for tests and CI. See docs/deployment/llm-profiles.md
# for the explicit Ollama non-mock profile.
AKL_LLM_DEFAULT_PROVIDER=mock
AKL_LLM_ENABLED_PROVIDERS=mock
AKL_LLM_MODEL_PROVIDER_MAP={}
AKL_LLM_DEFAULT_CHAT_MODEL=gemma4:12b
AKL_LLM_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_LLM_DEFAULT_MAX_TOKENS=512
AKL_LLM_ALLOW_MODEL_PULL=false
AKL_LLM_ALLOW_MODEL_DELETE=false
AKL_LLM_MODEL_PULL_TIMEOUT_SECONDS=1800

# HTTP provider resilience
AKL_LLM_REQUEST_TIMEOUT_SECONDS=30
AKL_LLM_RETRY_ATTEMPTS=2
AKL_LLM_RETRY_BACKOFF_SECONDS=0.25

# Rate limiting placeholder
AKL_RATE_LIMIT_ENABLED=false
AKL_RATE_LIMIT_PER_MINUTE=120

# Mock provider
AKL_MOCK_CHAT_RESPONSE=Mock response generated by LLM Gateway.
AKL_MOCK_EMBEDDING_DIMENSIONS=8

# Ollama
AKL_OLLAMA_BASE_URL=http://localhost:11434
AKL_OLLAMA_BASE_URLS=http://localhost:11434
AKL_OLLAMA_ENDPOINT_TIMEOUT_SECONDS=3
AKL_OLLAMA_THINK=false
AKL_LLM_SMOKE_CHAT_MODEL=gemma4:12b
AKL_LLM_SMOKE_EMBEDDING_MODEL=bge-m3

# vLLM / OpenAI-compatible endpoint.
# For vLLM this is commonly http://localhost:8000.
AKL_OPENAI_COMPAT_BASE_URL=http://localhost:8000
AKL_OPENAI_COMPAT_API_KEY=
