AKL_ENV=development
AKL_SERVICE_NAME=governance-service
AKL_SERVICE_VERSION=dev
AKL_LOG_LEVEL=INFO

# In production use AKL_AUTH_MODE=bearer and provide AKL_SERVICE_TOKEN.
AKL_AUTH_MODE=disabled
AKL_SERVICE_TOKEN=
AKL_UPSTREAM_BEARER_TOKEN=

# mock keeps the service self-contained for local development and tests.
# production requires http for both Registry and RAG clients.
AKL_GOVERNANCE_DEPENDENCY_MODE=mock
AKL_GOVERNANCE_REGISTRY_CLIENT_MODE=mock
AKL_GOVERNANCE_RAG_CLIENT_MODE=mock

AKL_REGISTRY_BASE_URL=http://localhost:8001/api/v1
AKL_RAG_BASE_URL=http://localhost:8082/api/v1

AKL_GOVERNANCE_REQUEST_TIMEOUT_SECONDS=30
AKL_GOVERNANCE_RETRY_ATTEMPTS=2
AKL_GOVERNANCE_RETRY_BACKOFF_SECONDS=0.25
AKL_GOVERNANCE_MAX_DOCUMENT_CHARS=200000
AKL_GOVERNANCE_MAX_CONTROL_CHUNKS=12
AKL_GOVERNANCE_DEFAULT_VALIDITY_ALERT_DAYS=60
AKL_GOVERNANCE_CONFIDENCE_HIGH_THRESHOLD=0.75
AKL_GOVERNANCE_CONFIDENCE_MEDIUM_THRESHOLD=0.5

# Comma-separated mock document ids denied by Registry authz simulation.
AKL_GOVERNANCE_MOCK_DENIED_DOCUMENT_IDS=doc_denied
