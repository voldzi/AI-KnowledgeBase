AKL_SERVICE_NAME=rag-retrieval-service
AKL_SERVICE_VERSION=dev
AKL_ENV=development
AKL_LOG_LEVEL=INFO

# disabled/mock are for local development only.
# bearer is legacy service-token auth; oidc requires a bearer JWT and forwards it downstream.
AKL_AUTH_MODE=disabled
AKL_SERVICE_TOKEN=
AKL_UPSTREAM_BEARER_TOKEN=
AKL_SERVICE_ACCOUNT_SUBJECT=svc-rag
AKL_SERVICE_ACCOUNT_ROLES=service_rag

# mock or http. Production must use http for all three clients.
AKL_RAG_DEPENDENCY_MODE=mock
AKL_RAG_REGISTRY_CLIENT_MODE=mock
AKL_RAG_RETRIEVER_MODE=mock
AKL_RAG_LLM_CLIENT_MODE=mock

AKL_REGISTRY_BASE_URL=http://localhost:8001/api/v1
AKL_QDRANT_BASE_URL=http://localhost:6333
AKL_QDRANT_COLLECTION=akl_document_chunks
AKL_LLM_GATEWAY_BASE_URL=http://localhost:8080/api/v1

AKL_RAG_EMBEDDING_MODEL=mock-embedding
AKL_RAG_CHAT_MODEL=mock-chat

AKL_RAG_REQUEST_TIMEOUT_SECONDS=30
AKL_RAG_RETRY_ATTEMPTS=2
AKL_RAG_RETRY_BACKOFF_SECONDS=0.25
AKL_RAG_DEFAULT_MAX_CHUNKS=8
AKL_RAG_RETRIEVAL_CANDIDATE_LIMIT=24
AKL_RAG_MAX_CONTEXT_CHARS=12000
AKL_RAG_HYBRID_DENSE_WEIGHT=0.35
AKL_RAG_NO_ANSWER_MIN_SCORE=0.35
AKL_RAG_CONFIDENCE_HIGH_THRESHOLD=0.75
AKL_RAG_CONFIDENCE_MEDIUM_THRESHOLD=0.5

# Comma-separated IDs denied by the mock Registry API.
AKL_RAG_MOCK_DENIED_DOCUMENT_IDS=doc_denied

# Phase 02 compatibility aliases. These are accepted by the service in addition
# to the AKL_* names above.
RAG_RETRIEVAL_MODE=mock
RAG_MOCK_MODE=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=akl_document_chunks
REGISTRY_API_URL=http://registry-api:8000
LLM_GATEWAY_URL=http://llm-gateway:8080
RAG_TOP_K=8
RAG_MIN_SCORE=0.35
RAG_REQUIRE_CITATIONS=true
RAG_ENABLE_RERANKING=true
RAG_AUTHZ_MODE=dev
