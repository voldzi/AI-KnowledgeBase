AKL_ENV=development
AKL_SERVICE_NAME=ingestion-service
AKL_SERVICE_VERSION=dev
AKL_LOG_LEVEL=INFO

# Inbound API auth. disabled/mock are dev/test only.
# bearer is legacy service-token auth; oidc requires a bearer JWT and forwards it downstream.
AKL_AUTH_MODE=disabled
AKL_SERVICE_TOKEN=

# Outbound service identity used when no caller bearer token is available.
AKL_SERVICE_ACCOUNT_SUBJECT=svc-ingestion
AKL_SERVICE_ACCOUNT_ROLES=service_ingestion,document_manager
AKL_SERVICE_ACCOUNT_TOKEN=

# Registry API integration.
AKL_INGESTION_REGISTRY_CLIENT_MODE=mock
AKL_REGISTRY_API_BASE_URL=http://localhost:8000
AKL_INGESTION_REGISTRY_MOCK_ALLOW=true
AKL_INGESTION_REGISTRY_MOCK_CLASSIFICATION=internal
AKL_INGESTION_REGISTRY_MOCK_ACCESS_SCOPE=role:reader

# Object storage. Local mode maps s3://bucket/key to AKL_OBJECT_STORAGE_ROOT/bucket/key.
AKL_INGESTION_OBJECT_STORAGE_MODE=local
AKL_OBJECT_STORAGE_ROOT=./object-storage
AKL_INGESTION_MAX_FILE_BYTES=52428800

# Parsing and OCR.
AKL_INGESTION_DEFAULT_PARSER_PROFILE=controlled_document
AKL_INGESTION_OCR_PROVIDER=sidecar
AKL_INGESTION_OCR_LANGUAGE=ces+eng
AKL_INGESTION_TESSERACT_COMMAND=tesseract
AKL_INGESTION_MIN_EXTRACTED_CHARS_BEFORE_OCR=20

# Chunking.
AKL_INGESTION_DEFAULT_CHUNKING_STRATEGY=legal_structured
AKL_INGESTION_CHUNK_TARGET_CHARS=1400
AKL_INGESTION_CHUNK_OVERLAP_CHARS=160
AKL_INGESTION_MAX_CHUNK_CHARS=3000
AKL_INGESTION_MAX_CHUNKS_PER_JOB=5000

# Embeddings through LLM Gateway. Mock is for dev/test only.
AKL_INGESTION_EMBEDDING_CLIENT_MODE=mock
AKL_LLM_GATEWAY_BASE_URL=http://localhost:8080
AKL_LLM_GATEWAY_TOKEN=
AKL_INGESTION_DEFAULT_EMBEDDING_MODEL=mock-embedding
AKL_INGESTION_EMBEDDING_PROFILE_MODEL_MAP={}
AKL_INGESTION_EMBEDDING_BATCH_SIZE=32
AKL_MOCK_EMBEDDING_DIMENSIONS=8

# Qdrant indexing. Mock is for dev/test only.
AKL_INGESTION_INDEXER_MODE=mock
AKL_QDRANT_BASE_URL=http://localhost:6333
AKL_QDRANT_API_KEY=
AKL_QDRANT_COLLECTION=akl_document_chunks
AKL_QDRANT_VECTOR_SIZE=1024
AKL_QDRANT_DISTANCE=Cosine
AKL_QDRANT_DELETE_EXISTING_VERSION=true

# Job/report persistence and execution mode.
AKL_INGESTION_JOB_STORE_PATH=./ingestion-jobs
AKL_INGESTION_PROCESS_JOBS_INLINE=true
AKL_INGESTION_REQUEST_TIMEOUT_SECONDS=30
