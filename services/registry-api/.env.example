AKL_ENV=development
AKL_SERVICE_VERSION=dev
AKL_AUTH_MODE=mock
AKL_DATABASE_URL=postgresql+psycopg://registry_api:change-me@localhost:5432/registry_api
AKL_AUTO_CREATE_SCHEMA=false

# Mock auth is for local development and tests only.
AKL_MOCK_SUBJECT=user_dev
AKL_MOCK_ROLES=["admin"]

# Required when AKL_AUTH_MODE=oidc.
AKL_OIDC_ISSUER=https://keycloak.example.local/realms/akl
AKL_OIDC_AUDIENCE=akl-registry-api
AKL_OIDC_JWKS_URL=https://keycloak.example.local/realms/akl/protocol/openid-connect/certs
# Exact Keycloak client ids accepted as machine identities. Route grants are
# default-deny; AIIP stays on its dedicated upload route and ingestion receives
# only authz/audit/document-read plus exact status-sync access.
AKL_TRUSTED_SERVICE_CLIENT_IDS=akb-rag-service,aiip-document-service,svc-ingestion
AKL_SERVICE_CLIENT_ROUTE_GRANTS=akb-rag-service=authz|audit|idempotency,aiip-document-service=aiip-upload,svc-ingestion=authz|audit|documents-read|ingestion-status
AKL_SERVICE_CLIENT_DELEGATIONS=akb-rag-service=aiip-service

# STRATOS Access Governance and anonymous publication verification.
AKL_STRATOS_AUTH_ME_URL=https://stratos.example.local/api/v1/auth/me
AKL_STRATOS_POLICY_BINDINGS_URL=https://stratos.example.local/api/v1/policy/bindings
AKL_STRATOS_POLICY_DECISIONS_URL=https://stratos.example.local/api/v1/policy/decisions
AKL_STRATOS_SERVICE_POLICY_BINDING_ID=pol_akb_internal_source_v1
AKL_STRATOS_INFORMATION_RESOURCES_URL=https://stratos.example.local/api/v1/information/resources
AKL_STRATOS_AIIP_AKB_RESOURCES_URL=https://stratos.example.local/api/v1/integrations/aiip/akb/resources
AKL_STRATOS_INFORMATION_PUBLICATIONS_URL=https://stratos.example.local/api/v1/information/publications
AKL_STRATOS_PUBLIC_DECISIONS_URL=https://stratos.example.local/api/v1/policy/public-decisions
AKB_POLICY_SERVICE_TOKEN=
AKB_AIIP_INGEST_SERVICE_TOKEN=
AKL_INGESTION_AUTHORIZATION_SECRET=replace-with-ingestion-authorization-secret-at-least-32-chars
AKL_INGESTION_AUTHORIZATION_SECRET_FILE=
AKL_INGESTION_AUTHORIZATION_TTL_SECONDS=60
AKL_PUBLIC_DELIVERY_INTERNAL_TOKEN=replace-with-shared-public-delivery-token-at-least-32-chars
AKL_PUBLIC_AUDIT_WINDOW_SECONDS=60
AKL_PUBLIC_AUDIT_RETENTION_DAYS=90
AKL_PUBLIC_AUDIT_PRUNE_INTERVAL_SECONDS=3600
AKL_ASSISTANT_CONVERSATION_RETENTION_DAYS=180
AKL_ASSISTANT_PURGE_ENABLED=true
AKL_ASSISTANT_PURGE_INTERVAL_SECONDS=3600
AKL_ASSISTANT_PURGE_BATCH_SIZE=500
AKL_ASSISTANT_DELETION_AUDIT_RETENTION_DAYS=730
AKL_REGISTRY_PUBLIC_RATE_WINDOW_MS=60000
AKL_REGISTRY_PUBLIC_RATE_PER_CLIENT_SLUG=600
AKL_REGISTRY_PUBLIC_RATE_GLOBAL=1200
AKL_REGISTRY_PUBLIC_CONCURRENCY_PER_CLIENT=32
AKL_REGISTRY_PUBLIC_CONCURRENCY_GLOBAL=64
AKL_REGISTRY_PUBLIC_LIMITER_MAX_KEYS=10000
AKL_REGISTRY_PUBLIC_TRUSTED_PROXY_HOPS=0
AKL_PUBLIC_CLIENT_KEY_SECRET=
