AKL_SERVICE_NAME=evaluation-service
AKL_SERVICE_VERSION=dev
AKL_ENV=development
AKL_LOG_LEVEL=INFO

# disabled is for local development only. Production uses oidc or bearer.
AKL_AUTH_MODE=disabled
AKL_SERVICE_TOKEN=
AKL_UPSTREAM_BEARER_TOKEN=
AKL_OIDC_ISSUER=
AKL_OIDC_AUDIENCE=akl-api
AKL_OIDC_JWKS_URL=
AKL_STRATOS_AUTH_ME_URL=
AKL_STRATOS_ACCESS_TIMEOUT_SECONDS=3

# mock or http. Production must call the real RAG service.
AKL_EVAL_DEPENDENCY_MODE=mock
AKL_EVAL_RAG_CLIENT_MODE=mock
AKL_EVAL_REGISTRY_CLIENT_MODE=mock

AKL_RAG_BASE_URL=http://localhost:8002/api/v1
AKL_REGISTRY_BASE_URL=http://localhost:8001/api/v1

AKL_EVAL_DATASETS_DIR=datasets
AKL_EVAL_SEED_DATASETS_DIR=
AKL_EVAL_REPORTS_DIR=reports
AKL_EVAL_SERVICE_ACTOR_ID=svc-evaluation

AKL_EVAL_REQUEST_TIMEOUT_SECONDS=30
AKL_EVAL_RETRY_ATTEMPTS=2
AKL_EVAL_RETRY_BACKOFF_SECONDS=0.25
AKL_EVAL_MAX_CASES_PER_RUN=200
AKL_EVAL_CONCURRENCY=4
AKL_EVAL_PASS_THRESHOLD=0.75
AKL_EVAL_ANSWER_EXCERPT_CHARS=500
AKL_EVAL_AUDIT_ENABLED=true
AKL_EVAL_GATE_RETRIEVAL_RECALL_MIN=0.95
AKL_EVAL_GATE_RETRIEVAL_NDCG_MIN=0.85
AKL_EVAL_GATE_FALSE_ZERO_RESULT_RATE_MAX=0.02
AKL_EVAL_GATE_AUTHORIZATION_LEAK_RATE_MAX=0
AKL_EVAL_GATE_CITATION_TRACEABILITY_MIN=1
AKL_EVAL_GATE_RETRIEVAL_LATENCY_P95_MS_MAX=3000
