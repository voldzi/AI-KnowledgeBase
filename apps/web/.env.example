AKL_ENV=development
AKL_API_CLIENT_MODE=mock
AKL_AUTH_MODE=mock

# Local docker-compose defaults use host ports 8001, 8090 and 8082.
# In Docker, use service DNS names from compose instead.
AKL_REGISTRY_API_BASE_URL=https://registry-api.local/api/v1
AKL_INGESTION_API_BASE_URL=https://ingestion.local/api/v1
AKL_RAG_API_BASE_URL=https://rag.local/api/v1
AKL_GOVERNANCE_API_BASE_URL=https://governance.local/api/v1

# Optional development token for local integration testing only. Never commit real tokens.
AKL_DEV_ACCESS_TOKEN=

# Mock auth identity used by production API clients in local development.
AKL_WEB_DEV_SUBJECT=user_dev
AKL_WEB_DEV_ROLES=admin,document_manager,reader
AKL_WEB_DEV_GROUPS=
AKL_WEB_OBJECT_STORAGE_ROOT=./object-storage
AKL_WEB_UPLOAD_BUCKET=akl-documents
AKL_WEB_DOWNLOAD_SIGNING_SECRET=
AKL_WEB_DOWNLOAD_TOKEN_TTL_SECONDS=300
# Optional override. By default source downloads use ${NEXT_PUBLIC_AKL_BASE_PATH}/api/documents/source/content.
# AKL_WEB_DOWNLOAD_PUBLIC_BASE_PATH=/api/documents/source/content

NEXT_PUBLIC_AKL_APP_NAME=AKB Platform
