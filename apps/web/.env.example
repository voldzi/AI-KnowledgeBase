AKL_ENV=development
AKL_API_CLIENT_MODE=mock
AKL_AUTH_MODE=mock
AKL_WEB_OIDC_ISSUER=https://login.zeleznalady.cz/realms/stratos
AKL_WEB_OIDC_CLIENT_ID=akl-web
AKL_WEB_PUBLIC_BASE_URL=https://stratos.zeleznalady.cz/akb
AKL_WEB_SESSION_SECRET=
AKL_WEB_INGESTION_TOKEN_URL=
AKL_WEB_INGESTION_CLIENT_ID=svc-akb-web-ingestion
AKL_WEB_INGESTION_CLIENT_SECRET=
AKL_WEB_INGESTION_CLIENT_SECRET_FILE=
AKL_WEB_STRATOS_AUTH_ME_URL=https://stratos.zeleznalady.cz/api/v1/auth/me
AKL_WEB_STRATOS_ACCESS_TIMEOUT_MS=3000
AKL_WEB_STRATOS_ACCESS_CACHE_TTL_MS=0

# Local docker-compose defaults use host ports 8001, 8090 and 8082.
# In Docker, use service DNS names from compose instead.
AKL_REGISTRY_API_BASE_URL=https://registry-api.local/api/v1
AKL_INGESTION_API_BASE_URL=https://ingestion.local/api/v1
AKL_RAG_API_BASE_URL=https://rag.local/api/v1
AKL_GOVERNANCE_API_BASE_URL=https://governance.local/api/v1
AKL_EVALUATION_API_BASE_URL=https://evaluation.local/api/v1

# Optional development token for local integration testing only. Never commit real tokens.
AKL_DEV_ACCESS_TOKEN=

# Mock auth identity used by production API clients in local development.
AKL_WEB_DEV_SUBJECT=user_dev
AKL_WEB_DEV_ROLES=admin,document_manager,reader
AKL_WEB_DEV_GROUPS=
AKL_WEB_DEV_CAPABILITIES=
AKL_WEB_DEV_SCOPES=
AKL_WEB_DEV_ORGANIZATION_ID=org_stratos
AKL_WEB_OBJECT_STORAGE_ROOT=./object-storage
AKL_WEB_UPLOAD_BUCKET=akl-documents
AKL_WEB_DOWNLOAD_SIGNING_SECRET=
AKL_WEB_DOWNLOAD_TOKEN_TTL_SECONDS=300
AKL_PUBLIC_DELIVERY_INTERNAL_TOKEN=replace-with-shared-public-delivery-token-at-least-32-chars
# Anonymous delivery limits are per web process. Keep the global limits enabled
# even when a validated proxy chain is used for per-client attribution.
AKL_PUBLIC_RATE_WINDOW_MS=60000
AKL_PUBLIC_RATE_PER_CLIENT_SLUG=30
AKL_PUBLIC_RATE_GLOBAL=600
AKL_PUBLIC_CONCURRENCY_PER_CLIENT=2
AKL_PUBLIC_CONCURRENCY_GLOBAL=24
AKL_PUBLIC_LIMITER_MAX_KEYS=10000
# 0 is conservative: all requests share one client bucket. Set the exact number
# only when every ingress proxy sanitizes/appends X-Forwarded-For.
AKL_PUBLIC_TRUSTED_PROXY_HOPS=0
# Optional; AKL_WEB_SESSION_SECRET is used as the HMAC key when this is empty.
AKL_PUBLIC_CLIENT_KEY_SECRET=
# Optional override. By default source downloads use ${NEXT_PUBLIC_AKL_BASE_PATH}/api/documents/source/content.
# AKL_WEB_DOWNLOAD_PUBLIC_BASE_PATH=/api/documents/source/content

NEXT_PUBLIC_AKL_APP_NAME=AKB Platform
NEXT_PUBLIC_STRATOS_HOME_URL=https://stratos.zeleznalady.cz
NEXT_PUBLIC_PROJECTFLOW_URL=https://stratos.zeleznalady.cz/project
NEXT_PUBLIC_ARCHFLOW_URL=https://stratos.zeleznalady.cz/arch
NEXT_PUBLIC_PROCESSFORGE_URL=https://stratos.zeleznalady.cz/process
NEXT_PUBLIC_AIIP_PUBLIC_URL=https://stratos.zeleznalady.cz/aiip
NEXT_PUBLIC_AKB_PUBLIC_URL=https://stratos.zeleznalady.cz/akb
