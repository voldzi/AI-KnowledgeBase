# AKL local production example.
# Copy to .env.local-prod and adjust local passwords/ports before running.

COMPOSE_PROJECT_NAME=akl
AKL_ENV=development
AKL_SERVICE_VERSION=local-prod
AKL_LOG_LEVEL=INFO

POSTGRES_DB=akl
POSTGRES_USER=akl_platform
POSTGRES_PASSWORD=change-me-local-postgres
MINIO_ROOT_USER=akl_minio
MINIO_ROOT_PASSWORD=change-me-local-minio
MINIO_DEFAULT_BUCKET=akl-documents

AKL_LLM_DEFAULT_PROVIDER=ollama
AKL_LLM_ENABLED_PROVIDERS=mock,ollama
AKL_LLM_DEFAULT_CHAT_MODEL=gemma4:12b-mlx
AKL_LLM_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_LLM_DEFAULT_MAX_TOKENS=512
AKL_OLLAMA_BASE_URL=http://host.docker.internal:11434
AKL_OLLAMA_THINK=false

AKL_INGESTION_EMBEDDING_CLIENT_MODE=http
AKL_INGESTION_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_INGESTION_INDEXER_MODE=qdrant

AKL_RAG_DEPENDENCY_MODE=http
AKL_RAG_REGISTRY_CLIENT_MODE=http
AKL_RAG_RETRIEVER_MODE=qdrant
AKL_RAG_LLM_CLIENT_MODE=http
AKL_RAG_CHAT_MODEL=gemma4:12b-mlx
AKL_RAG_EMBEDDING_MODEL=bge-m3
AKL_RAG_ANSWER_MAX_TOKENS=512
AKL_RAG_AUTHZ_MODE=dev
AKL_RAG_REQUIRE_CITATIONS=true
AKL_RAG_ENABLE_RERANKING=true

AKL_QDRANT_COLLECTION=akl_document_chunks
AKL_QDRANT_VECTOR_SIZE=1024
AKL_QDRANT_DISTANCE=Cosine

AKL_WEB_API_CLIENT_MODE=production
AKL_WEB_AUTH_MODE=mock
AKL_WEB_DEV_SUBJECT=user_dev
AKL_WEB_DEV_ROLES=admin,document_manager,reader

REGISTRY_API_PORT=8001
INGESTION_SERVICE_PORT=8090
RAG_RETRIEVAL_SERVICE_PORT=8082
GOVERNANCE_SERVICE_PORT=8085
LLM_GATEWAY_SERVICE_PORT=8083
WEB_PORT=3002
QDRANT_HTTP_PORT=6333
