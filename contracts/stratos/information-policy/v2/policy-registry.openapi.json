{
  "openapi": "3.1.0",
  "info": { "title": "STRATOS Policy Registry Contract", "version": "2.0.0" },
  "paths": {
    "/api/v1/policy/bundle": { "get": { "operationId": "getPolicyBundle", "responses": { "200": { "description": "Current signed policy bundle", "content": { "application/json": { "schema": { "type": "object" } } } } } } },
    "/api/v1/policy/bindings": { "post": { "operationId": "registerPolicyBinding", "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PolicyBindingInput" } } } }, "responses": { "200": { "description": "Idempotently registered binding", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PolicyBinding" } } } } } } },
    "/api/v1/policy/bindings/{bindingId}": { "get": { "operationId": "getPolicyBinding", "parameters": [{ "name": "bindingId", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Registered binding", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PolicyBinding" } } } }, "404": { "description": "Unknown binding" } } } },
    "/api/v1/policy/decisions": { "post": { "operationId": "decidePolicy", "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DecisionRequest" } } } }, "responses": { "200": { "description": "Policy decision", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Decision" } } } } } } }
  },
  "components": { "schemas": {
    "PolicyBindingInput": { "type": "object", "additionalProperties": false, "required": ["policyVersion", "handlingClass", "legalClassification", "obligations"], "properties": { "policyBindingId": { "type": "string" }, "policyVersion": { "const": "information-policy-2.0.0" }, "handlingClass": { "enum": ["PUBLIC", "INTERNAL", "RESTRICTED"] }, "legalClassification": { "const": "NONE" }, "tlp": { "type": ["string", "null"] }, "pap": { "type": ["string", "null"] }, "contentCategories": { "type": "array", "items": { "type": "string" } }, "audience": { "type": "object" }, "obligations": { "type": "array", "items": { "type": "string" } } } },
    "PolicyBinding": { "allOf": [{ "$ref": "#/components/schemas/PolicyBindingInput" }, { "type": "object", "required": ["policyBindingId", "organizationId", "policyHash"], "properties": { "policyBindingId": { "type": "string" }, "organizationId": { "const": "org_stratos" }, "policyHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" } } }] },
    "DecisionRequest": { "type": "object", "additionalProperties": false, "required": ["applicationId", "capabilityId", "operation", "scope", "policyBinding"], "properties": { "actorSubjectId": { "type": "string", "description": "Required only for authenticated service-to-service delegated decisions." }, "applicationId": { "type": "string" }, "capabilityId": { "type": "string" }, "operation": { "type": "string" }, "scope": { "type": "object" }, "policyBinding": { "type": ["object", "null"] } } },
    "Decision": { "type": "object", "additionalProperties": false, "required": ["decision", "reasonCodes", "obligations", "policyVersion", "decisionId"], "properties": { "decision": { "enum": ["ALLOW", "DENY"] }, "reasonCodes": { "type": "array", "items": { "type": "string" } }, "obligations": { "type": "array", "items": { "type": "string" } }, "policyVersion": { "type": "string" }, "decisionId": { "type": "string" } } }
  } }
}
