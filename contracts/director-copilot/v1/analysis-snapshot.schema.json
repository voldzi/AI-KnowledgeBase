{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stratos.zeleznalady.cz/akb/contracts/director-copilot/v1/analysis-snapshot.schema.json",
  "title": "AKB Director Copilot AnalysisSnapshot V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "snapshot_id", "created_at", "correlation_id", "plan", "projection_hash", "evidence", "unavailable_sources", "strictest_policy", "document_context_tags", "document_context_bindings", "snapshot_hash"],
  "properties": {
    "schema_version": { "const": "director-copilot-analysis-snapshot-1" },
    "snapshot_id": { "type": "string", "pattern": "^snap_[a-f0-9]{16,64}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "correlation_id": { "type": "string", "minLength": 8, "maxLength": 200 },
    "plan": { "$ref": "query-plan.schema.json" },
    "projection_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "evidence": { "type": "array", "maxItems": 400, "items": { "$ref": "evidence-item.schema.json" } },
    "unavailable_sources": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "status", "code"],
        "properties": {
          "source": { "enum": ["STRATOS_AKB", "STRATOS_BUDGET", "STRATOS_PROJECTFLOW"] },
          "status": { "enum": ["partial", "unavailable", "not_authorized"] },
          "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,79}$" }
        }
      }
    },
    "strictest_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "audience_mode", "audience", "obligations", "source_policies"],
      "properties": {
        "classification": { "$ref": "domain-tool.schema.json#/$defs/classification" },
        "audience_mode": { "const": "all_source_policies_required" },
        "audience": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 160 } },
        "obligations": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "enum": ["AUDIT_ACCESS", "NO_EXTERNAL_AI", "LOCAL_PROCESSING_ONLY", "NO_PUBLIC_EXPORT", "NO_EXPORT", "WATERMARK", "ENCRYPT_AT_REST", "RECIPIENT_CONFIRMATION", "ORIGINATOR_APPROVAL", "PAP_ENFORCEMENT"] } },
        "source_policies": {
          "type": "array",
          "minItems": 1,
          "maxItems": 200,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_system", "binding_id", "version", "hash"],
            "properties": {
              "source_system": { "enum": ["STRATOS_AKB", "STRATOS_BUDGET", "STRATOS_PROJECTFLOW"] },
              "binding_id": { "type": "string", "minLength": 8, "maxLength": 200 },
              "version": { "const": "information-policy-2.0.0" },
              "hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
            }
          }
        }
      }
    },
    "document_context_tags": { "type": "array", "maxItems": 100, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 120 } },
    "document_context_bindings": {
      "type": "array",
      "maxItems": 25,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonical_id", "tags"],
        "properties": {
          "canonical_id": { "type": "string", "pattern": "^stratos:project:[A-Za-z0-9._:/-]+$", "maxLength": 300 },
          "tags": { "type": "array", "minItems": 1, "maxItems": 4, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 120 } }
        }
      }
    },
    "snapshot_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
