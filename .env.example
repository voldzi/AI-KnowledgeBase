# AKB Platform local configuration template.
# Copy to .env for local use. Values below are placeholders, not production secrets.

COMPOSE_PROJECT_NAME=akl
AKL_ENV=development
AKL_AUTH_MODE=mock
AKL_PUBLIC_HOST=localhost
AKL_PUBLIC_BASE_URL=http://localhost:8080
TZ=Europe/Prague

# Reverse proxy
AKL_PROXY_HTTP_PORT=8080
AKL_PROXY_CONTAINER_PORT=8080
AKL_PROXY_HTTPS_PORT=8443
AKL_PROXY_HTTPS_CONTAINER_PORT=8443
CADDY_ADMIN_PORT=2019
AKL_TLS_MODE=internal

# Images. Pin these to immutable digests for regulated production deployments.
CADDY_IMAGE=caddy:2-alpine
POSTGRES_IMAGE=postgres:16-alpine
QDRANT_IMAGE=qdrant/qdrant:latest
MINIO_IMAGE=minio/minio:latest
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:latest
PROMETHEUS_IMAGE=prom/prometheus:latest
GRAFANA_IMAGE=grafana/grafana:latest
LOKI_IMAGE=grafana/loki:latest
OLLAMA_IMAGE=ollama/ollama:latest
PLATFORM_STATUS_IMAGE=akl/platform-status:local

# Service defaults
AKL_SERVICE_VERSION=dev
AKL_LOG_LEVEL=INFO

# Platform status service
PLATFORM_READY_TIMEOUT_SECONDS=2
PLATFORM_READY_CHECKS=qdrant=http://qdrant:6333/readyz,minio=http://minio:9000/minio/health/ready,keycloak=http://keycloak:9000/health/ready,prometheus=http://prometheus:9090/-/ready

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=akl
POSTGRES_USER=akl_platform
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_MULTIPLE_DATABASES=akl_registry,akl_keycloak,akl_evaluation,akl_governance

# Qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTIONS=akl_document_chunks

# MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=akl_minio
MINIO_ROOT_PASSWORD=replace-with-local-minio-password
MINIO_DEFAULT_BUCKET=akl-documents

# Keycloak
KEYCLOAK_HTTP_PORT=8081
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-local-keycloak-admin-password
KEYCLOAK_DB_USERNAME=akl_platform
KEYCLOAK_DB_PASSWORD=replace-with-local-postgres-password
KEYCLOAK_REALM=akl

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-local-grafana-password
GRAFANA_ROOT_URL=http://localhost:8080/grafana/
LOKI_PORT=3100

# AI runtime
OLLAMA_PORT=11434
# Current real local RAG profile.
AKL_LLM_DEFAULT_PROVIDER=ollama
AKL_LLM_ENABLED_PROVIDERS=ollama
AKL_LLM_MODEL_PROVIDER_MAP={"gemma4:12b-mlx":"ollama","bge-m3":"ollama"}
AKL_LLM_DEFAULT_CHAT_MODEL=gemma4:12b-mlx
AKL_LLM_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_LLM_DEFAULT_MAX_TOKENS=512
AKL_LLM_ALLOW_MODEL_PULL=true
AKL_LLM_ALLOW_MODEL_DELETE=false
AKL_LLM_MODEL_PULL_TIMEOUT_SECONDS=1800
AKL_OLLAMA_BASE_URL=http://ollama:11434
# Optional comma-separated failover candidates. AKB does not scan the LAN.
AKL_OLLAMA_BASE_URLS=http://ollama:11434
AKL_OLLAMA_THINK=false
AKL_OPENAI_COMPAT_BASE_URL=http://vllm:8000
AKL_OPENAI_COMPAT_API_KEY=
AKL_LLM_REQUEST_TIMEOUT_SECONDS=30
AKL_LLM_RETRY_ATTEMPTS=2
AKL_LLM_RETRY_BACKOFF_SECONDS=0.25
AKL_MOCK_CHAT_RESPONSE=Mock response generated by LLM Gateway.
AKL_MOCK_EMBEDDING_DIMENSIONS=8
AKL_LLM_SMOKE_CHAT_MODEL=gemma4:12b-mlx
AKL_LLM_SMOKE_EMBEDDING_MODEL=bge-m3

# Reverse proxy upstreams. Other CODEX threads can replace these with remote URLs.
WEB_PORT=3002
PLATFORM_STATUS_UPSTREAM=platform-status:8080
WEB_UPSTREAM=web:3000
REGISTRY_UPSTREAM=registry-api:8000
INGESTION_UPSTREAM=ingestion-service:8090
RAG_UPSTREAM=rag-retrieval-service:8080
LLM_GATEWAY_UPSTREAM=llm-gateway-service:8080
EVALUATION_UPSTREAM=evaluation-service:8080
GOVERNANCE_UPSTREAM=governance-service:8080
GRAFANA_UPSTREAM=grafana:3000

# Service-to-service URLs and integration modes.
AKL_API_CLIENT_MODE=production
AKL_WEB_AUTH_MODE=mock
AKL_WEB_BASE_PATH=/akb
AKL_WEB_PUBLIC_BASE_URL=http://docker.home.cz/akb
AKL_WEB_OIDC_ISSUER=http://keycloak:8080/realms/stratos
AKL_WEB_OIDC_CLIENT_ID=akl-web
AKL_WEB_SESSION_SECRET=change-me-generate-secure-session-secret
AKL_WEB_REGISTRY_API_BASE_URL=http://registry-api:8000/api/v1
AKL_WEB_INGESTION_API_BASE_URL=http://ingestion-service:8090/api/v1
AKL_WEB_RAG_API_BASE_URL=http://rag-retrieval-service:8080/api/v1
AKL_WEB_GOVERNANCE_API_BASE_URL=http://governance-service:8080/api/v1
AKL_WEB_UPLOAD_BUCKET=akl-documents
AKL_WEB_UPLOAD_SIGNING_SECRET=replace-with-local-upload-signing-secret
AKL_WEB_UPLOAD_MAX_FILE_BYTES=52428800
AKL_WEB_DOWNLOAD_SIGNING_SECRET=replace-with-local-download-signing-secret
AKL_WEB_DOWNLOAD_TOKEN_TTL_SECONDS=300
# Optional override. By default source downloads use ${NEXT_PUBLIC_AKL_BASE_PATH}/api/documents/source/content.
# AKL_WEB_DOWNLOAD_PUBLIC_BASE_PATH=/api/documents/source/content
AKL_DEV_ACCESS_TOKEN=
AKL_EVAL_SERVICE_TOKEN=change-me-generate-secure-eval-token
AKL_GOVERNANCE_SERVICE_TOKEN=change-me-generate-secure-governance-token

AKL_REGISTRY_AUTH_MODE=mock
AKL_REGISTRY_DATABASE_URL=postgresql+psycopg://akl_platform:replace-with-local-postgres-password@postgres:5432/akl_registry
AKL_REGISTRY_AUTO_CREATE_SCHEMA=true
AKL_MOCK_SUBJECT=user_dev
AKL_MOCK_ROLES=["admin"]
AKL_OIDC_ISSUER=http://keycloak:8080/realms/akl
AKL_OIDC_AUDIENCE=akl-registry-api
AKL_OIDC_JWKS_URL=http://keycloak:8080/realms/akl/protocol/openid-connect/certs

AKL_INGESTION_AUTH_MODE=mock
AKL_INGESTION_REGISTRY_CLIENT_MODE=http
AKL_INGESTION_REGISTRY_API_BASE_URL=http://registry-api:8000
AKL_INGESTION_SERVICE_ACCOUNT_SUBJECT=svc-ingestion
AKL_INGESTION_SERVICE_ACCOUNT_ROLES=service_ingestion,document_manager
AKL_INGESTION_OBJECT_STORAGE_MODE=local
AKL_INGESTION_EMBEDDING_CLIENT_MODE=http
AKL_INGESTION_LLM_GATEWAY_BASE_URL=http://llm-gateway-service:8080/api/v1
AKL_INGESTION_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_INGESTION_INDEXER_MODE=qdrant
AKL_INGESTION_PROCESS_JOBS_INLINE=true

AKL_RAG_AUTH_MODE=mock
AKL_RAG_SERVICE_ACCOUNT_SUBJECT=svc-rag
AKL_RAG_SERVICE_ACCOUNT_ROLES=service_rag
AKL_RAG_DEPENDENCY_MODE=http
AKL_RAG_REGISTRY_CLIENT_MODE=http
AKL_RAG_RETRIEVER_MODE=qdrant
AKL_RAG_LLM_CLIENT_MODE=http
AKL_RAG_AUTHZ_MODE=dev
AKL_RAG_REGISTRY_BASE_URL=http://registry-api:8000/api/v1
AKL_RAG_LLM_GATEWAY_BASE_URL=http://llm-gateway-service:8080/api/v1
AKL_RAG_CHAT_MODEL=gemma4:12b-mlx
AKL_RAG_EMBEDDING_MODEL=bge-m3
AKL_RAG_ANSWER_MAX_TOKENS=512
AKL_RAG_SOURCE_CONTEXT_WINDOW=1
AKL_RAG_REQUIRE_CITATIONS=true
AKL_RAG_ENABLE_RERANKING=true

AKL_LLM_AUTH_MODE=mock

AKL_EVAL_AUTH_MODE=mock
AKL_EVAL_DEPENDENCY_MODE=mock
AKL_EVAL_RAG_CLIENT_MODE=mock
AKL_EVAL_REGISTRY_CLIENT_MODE=mock
AKL_EVAL_RAG_BASE_URL=http://rag-retrieval-service:8080/api/v1
AKL_EVAL_REGISTRY_BASE_URL=http://registry-api:8000/api/v1

AKL_GOVERNANCE_AUTH_MODE=mock
AKL_GOVERNANCE_DEPENDENCY_MODE=mock
AKL_GOVERNANCE_REGISTRY_CLIENT_MODE=mock
AKL_GOVERNANCE_RAG_CLIENT_MODE=mock
AKL_GOVERNANCE_RAG_BASE_URL=http://rag-retrieval-service:8080/api/v1
AKL_GOVERNANCE_REGISTRY_BASE_URL=http://registry-api:8000/api/v1

AKL_QDRANT_BASE_URL=http://qdrant:6333
AKL_QDRANT_COLLECTION=akl_document_chunks
AKL_QDRANT_VECTOR_SIZE=1024
AKL_QDRANT_DISTANCE=Cosine

# Mock/dev-test profile overrides. Use this only for isolated unit tests or
# deterministic development without Ollama/Qdrant-backed embeddings. Mock
# embeddings are 8-dimensional and must not be mixed with the real bge-m3
# Qdrant collection, which is 1024-dimensional.
# AKL_LLM_DEFAULT_PROVIDER=mock
# AKL_LLM_ENABLED_PROVIDERS=mock
# AKL_LLM_MODEL_PROVIDER_MAP={}
# AKL_LLM_ALLOW_MODEL_PULL=false
# AKL_INGESTION_REGISTRY_CLIENT_MODE=mock
# AKL_INGESTION_EMBEDDING_CLIENT_MODE=mock
# AKL_INGESTION_DEFAULT_EMBEDDING_MODEL=mock-embedding
# AKL_INGESTION_INDEXER_MODE=mock
# AKL_RAG_DEPENDENCY_MODE=mock
# AKL_RAG_REGISTRY_CLIENT_MODE=mock
# AKL_RAG_RETRIEVER_MODE=mock
# AKL_RAG_LLM_CLIENT_MODE=mock
# AKL_RAG_CHAT_MODEL=mock-chat
# AKL_RAG_EMBEDDING_MODEL=mock-embedding

# Keycloak/OIDC profile. Browser login is not implemented yet; until
# then API clients must provide Authorization: Bearer <jwt> plus X-AKL-Subject
# or use service-account tokens from a secret manager/local shell.
# AKL_WEB_AUTH_MODE=oidc
# AKL_REGISTRY_AUTH_MODE=oidc
# AKL_INGESTION_AUTH_MODE=oidc
# AKL_RAG_AUTH_MODE=oidc
# AKL_LLM_AUTH_MODE=oidc
# AKL_INGESTION_REGISTRY_CLIENT_MODE=http
# AKL_RAG_REGISTRY_CLIENT_MODE=http

# Backup and restore
BACKUP_DIR=infra/backup/artifacts
BACKUP_RETENTION_DAYS=14
BACKUP_COMPOSE_FILE=infra/docker-compose/docker-compose.dev.yml
BACKUP_ENV_FILE=.env
QDRANT_BACKUP_URL=http://localhost:6333
MINIO_BACKUP_ALIAS=akl
