# Mock/dev-test profile overrides. Use this only for isolated unit tests or
# deterministic development without Ollama/Qdrant-backed embeddings. Mock
# embeddings are 8-dimensional and must not be mixed with the real bge-m3
# Qdrant collection, which is 1024-dimensional.
# AKL_LLM_DEFAULT_PROVIDER=mock
# AKL_LLM_ENABLED_PROVIDERS=mock
# AKL_LLM_MODEL_PROVIDER_MAP={}
# AKL_LLM_ALLOW_MODEL_PULL=false
# AKL_INGESTION_REGISTRY_CLIENT_MODE=mock
# AKL_INGESTION_EMBEDDING_CLIENT_MODE=mock
# AKL_INGESTION_DEFAULT_EMBEDDING_MODEL=mock-embedding
# AKL_INGESTION_INDEXER_MODE=mock
# AKL_RAG_DEPENDENCY_MODE=mock
# AKL_RAG_REGISTRY_CLIENT_MODE=mock
# AKL_RAG_RETRIEVER_MODE=mock
# AKL_RAG_FULLTEXT_MODE=qdrant
# AKL_RAG_LLM_CLIENT_MODE=mock
# AKL_RAG_CHAT_MODEL=mock-chat
# AKL_RAG_HIGH_QUALITY_CHAT_MODEL=
# AKL_RAG_EMBEDDING_MODEL=mock-embedding

# Keycloak/OIDC profile. Browser login is not implemented yet; until
# then API clients must provide Authorization: Bearer <jwt> plus X-AKL-Subject
# or use service-account tokens from a secret manager/local shell.
# AKL_WEB_AUTH_MODE=oidc
# AKL_REGISTRY_AUTH_MODE=oidc
# AKL_INGESTION_AUTH_MODE=oidc
# AKL_RAG_AUTH_MODE=oidc
# AKL_LLM_AUTH_MODE=oidc
# AKL_INGESTION_REGISTRY_CLIENT_MODE=http
# AKL_RAG_REGISTRY_CLIENT_MODE=http

# Backup and restore
BACKUP_DIR=infra/backup/artifacts
BACKUP_RETENTION_DAYS=14
BACKUP_COMPOSE_FILE=infra/docker-compose/docker-compose.dev.yml
BACKUP_ENV_FILE=.env
QDRANT_BACKUP_URL=http://localhost:6333
MINIO_BACKUP_ALIAS=akl
