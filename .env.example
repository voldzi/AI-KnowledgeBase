# AKB Platform local configuration template.
# Copy to .env for local use. Values below are placeholders, not production secrets.

COMPOSE_PROJECT_NAME=akl
AKL_ENV=development
AKL_AUTH_MODE=mock
AKL_PUBLIC_HOST=localhost
AKL_PUBLIC_BASE_URL=http://localhost:8080
TZ=Europe/Prague

# Reverse proxy
AKL_PROXY_HTTP_PORT=8080
AKL_CHAT_WEB_HTTP_PORT=3221
AKL_PROXY_CONTAINER_PORT=8080
AKL_PROXY_HTTPS_PORT=8443
AKL_PROXY_HTTPS_CONTAINER_PORT=8443
CADDY_ADMIN_PORT=2019
AKL_TLS_MODE=internal

# Images. Pin these to immutable digests for regulated production deployments.
CADDY_IMAGE=caddy:2-alpine
POSTGRES_IMAGE=postgres:16-alpine
QDRANT_IMAGE=qdrant/qdrant:1.18.2
OPENSEARCH_IMAGE=opensearchproject/opensearch:2
MINIO_IMAGE=minio/minio:latest
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:latest
PROMETHEUS_IMAGE=prom/prometheus:latest
GRAFANA_IMAGE=grafana/grafana:latest
LOKI_IMAGE=grafana/loki:latest
OLLAMA_IMAGE=ollama/ollama:latest
PLATFORM_STATUS_IMAGE=akl/platform-status:local

# Service defaults
AKL_SERVICE_VERSION=dev
AKL_LOG_LEVEL=INFO

# Canonical STRATOS content-security profile. Pilot performs no external scan.
STRATOS_CONTENT_SECURITY_MODE=disabled
STRATOS_CONTENT_SECURITY_REQUIRED=false
STRATOS_CONTENT_SECURITY_ENDPOINT=

# Platform status service
PLATFORM_READY_TIMEOUT_SECONDS=2
PLATFORM_READY_CHECKS=qdrant=http://qdrant:6333/readyz,opensearch=http://opensearch:9200,minio=http://minio:9000/minio/health/ready,keycloak=http://keycloak:9000/health/ready,prometheus=http://prometheus:9090/-/ready

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=akl
POSTGRES_USER=akl_platform
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_MULTIPLE_DATABASES=akl_registry,akl_keycloak,akl_evaluation,akl_governance

# Qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTIONS=akl_document_chunks

# OpenSearch fulltext
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_PERFORMANCE_ANALYZER_PORT=9600
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g

# MinIO
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=akl_minio
MINIO_ROOT_PASSWORD=replace-with-local-minio-password
MINIO_DEFAULT_BUCKET=akl-documents

# Keycloak
KEYCLOAK_HTTP_PORT=8081
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-local-keycloak-admin-password
KEYCLOAK_DB_USERNAME=akl_platform
KEYCLOAK_DB_PASSWORD=replace-with-local-postgres-password
KEYCLOAK_REALM=akl

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-local-grafana-password
GRAFANA_ROOT_URL=http://localhost:8080/grafana/
LOKI_PORT=3100

# AI runtime
OLLAMA_PORT=11434
# Current real local RAG profile.
AKL_LLM_DEFAULT_PROVIDER=ollama
AKL_LLM_ENABLED_PROVIDERS=ollama
AKL_LLM_MODEL_PROVIDER_MAP={"gemma4:12b-mlx":"ollama","gemma4:31b-mlx":"ollama","bge-m3":"ollama","qwen3-embedding:8b":"ollama"}
AKL_LLM_DEFAULT_CHAT_MODEL=gemma4:12b-mlx
AKL_LLM_CHAT_MODEL_FALLBACKS={"gemma4:31b-mlx":["gemma4:12b-mlx"]}
AKL_LLM_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_LLM_DEFAULT_EMBEDDING_DIMENSIONS=
AKL_LLM_DEFAULT_MAX_TOKENS=512
AKL_LLM_ALLOW_MODEL_PULL=true
AKL_LLM_ALLOW_MODEL_DELETE=false
AKL_LLM_MODEL_PULL_TIMEOUT_SECONDS=1800
AKL_OLLAMA_BASE_URL=http://ollama:11434
# Optional comma-separated failover candidates. AKB does not scan the LAN.
AKL_OLLAMA_BASE_URLS=http://ollama:11434,http://192.168.200.3:11434,http://192.168.200.2:11434,http://192.168.1.176:11434
AKL_OLLAMA_THINK=false
AKL_OPENAI_COMPAT_BASE_URL=http://vllm:8000
AKL_OPENAI_COMPAT_API_KEY=
AKL_LLM_REQUEST_TIMEOUT_SECONDS=30
AKL_LLM_RETRY_ATTEMPTS=2
AKL_LLM_RETRY_BACKOFF_SECONDS=0.25
AKL_MOCK_CHAT_RESPONSE=Mock response generated by LLM Gateway.
AKL_MOCK_EMBEDDING_DIMENSIONS=8
AKL_LLM_SMOKE_CHAT_MODEL=gemma4:12b-mlx
AKL_LLM_SMOKE_EMBEDDING_MODEL=bge-m3

# Reverse proxy upstreams. Other CODEX threads can replace these with remote URLs.
WEB_PORT=3002
PLATFORM_STATUS_UPSTREAM=platform-status:8080
WEB_UPSTREAM=akl-platform-web:3000
REGISTRY_UPSTREAM=registry-api:8000
INGESTION_UPSTREAM=ingestion-service:8090
RAG_UPSTREAM=rag-retrieval-service:8080
LLM_GATEWAY_UPSTREAM=llm-gateway-service:8080
EVALUATION_UPSTREAM=evaluation-service:8080
GOVERNANCE_UPSTREAM=governance-service:8080
GRAFANA_UPSTREAM=grafana:3000

# Service-to-service URLs and integration modes.
AKL_API_CLIENT_MODE=production
AKL_WEB_AUTH_MODE=mock
AKL_WEB_BASE_PATH=/akb
AKL_WEB_PUBLIC_BASE_URL=http://docker.home.cz/akb
AKL_CHAT_WEB_PUBLIC_BASE_URL=http://docker.home.cz:3221
AKL_CHAT_WEB_OIDC_ISSUER=http://localhost:8080/realms/stratos
AKL_CHAT_WEB_OIDC_CLIENT_ID=akb-chat-web
AKL_CHAT_WEB_SESSION_SECRET=replace-with-separate-local-session-secret
AKL_CHAT_WEB_STRATOS_AUTH_ME_URL=http://localhost:4200/api/v1/auth/me
AKL_WEB_OIDC_ISSUER=http://keycloak:8080/realms/stratos
AKL_WEB_OIDC_CLIENT_ID=akl-web
AKL_WEB_SESSION_SECRET=change-me-generate-secure-session-secret
AKL_WEB_INGESTION_TOKEN_URL=
AKL_WEB_INGESTION_CLIENT_ID=svc-akb-web-ingestion
AKL_WEB_INGESTION_CLIENT_SECRET=
AKL_WEB_INGESTION_CLIENT_SECRET_FILE=
AKL_WEB_STRATOS_AUTH_ME_URL=http://host.docker.internal:4000/api/v1/auth/me
AKL_WEB_STRATOS_ACCESS_TIMEOUT_MS=3000
AKL_WEB_STRATOS_ACCESS_CACHE_TTL_MS=0
# Governed Director Copilot federation. Keep disabled until Budget and
# ProjectFlow pass contracts/director-copilot/v1 fixtures and history
# reauthorization is accepted.
AKL_DIRECTOR_COPILOT_ENABLED=false
AKL_DIRECTOR_COPILOT_TOKEN_URL=
AKL_DIRECTOR_COPILOT_CLIENT_ID=svc-akb-director-copilot
AKL_DIRECTOR_COPILOT_CLIENT_SECRET=
AKL_DIRECTOR_COPILOT_CLIENT_SECRET_FILE=
AKL_DIRECTOR_COPILOT_BUDGET_BASE_URL=
AKL_DIRECTOR_COPILOT_PROJECTFLOW_BASE_URL=
AKL_DIRECTOR_COPILOT_TIMEOUT_MS=8000
AKL_DIRECTOR_COPILOT_MAX_RESPONSE_BYTES=262144
AKL_WEB_REGISTRY_API_BASE_URL=http://registry-api:8000/api/v1
AKL_WEB_INGESTION_API_BASE_URL=http://ingestion-service:8090/api/v1
AKL_WEB_RAG_API_BASE_URL=http://rag-retrieval-service:8080/api/v1
AKL_WEB_GOVERNANCE_API_BASE_URL=http://governance-service:8080/api/v1
AKL_WEB_UPLOAD_BUCKET=akl-documents
AKL_WEB_UPLOAD_SIGNING_SECRET=replace-with-local-upload-signing-secret
AKL_WEB_UPLOAD_MAX_FILE_BYTES=52428800
AKL_WEB_BUDGET_UPLOAD_MAX_FILE_BYTES=134217728
AKL_WEB_STRATOS_BUDGET_SERVICE_RATE_LIMIT=300
AKL_WEB_STRATOS_BUDGET_SERVICE_RATE_WINDOW_SECONDS=60
AKL_WEB_DOWNLOAD_SIGNING_SECRET=replace-with-local-download-signing-secret
AKL_WEB_DOWNLOAD_TOKEN_TTL_SECONDS=300
AKL_PUBLIC_DELIVERY_INTERNAL_TOKEN=replace-with-shared-public-delivery-token-at-least-32-chars
AKL_PUBLIC_RATE_WINDOW_MS=60000
AKL_PUBLIC_RATE_PER_CLIENT_SLUG=30
AKL_PUBLIC_RATE_GLOBAL=600
AKL_PUBLIC_CONCURRENCY_PER_CLIENT=2
AKL_PUBLIC_CONCURRENCY_GLOBAL=24
AKL_PUBLIC_LIMITER_MAX_KEYS=10000
# Keep 0 unless the exact sanitized ingress proxy chain is known.
AKL_PUBLIC_TRUSTED_PROXY_HOPS=0
AKL_PUBLIC_CLIENT_KEY_SECRET=
AKL_PUBLIC_AUDIT_WINDOW_SECONDS=60
AKL_PUBLIC_AUDIT_RETENTION_DAYS=90
AKL_PUBLIC_AUDIT_PRUNE_INTERVAL_SECONDS=3600
AKL_ASSISTANT_CONVERSATION_RETENTION_DAYS=180
AKL_ASSISTANT_PURGE_ENABLED=true
AKL_ASSISTANT_PURGE_INTERVAL_SECONDS=3600
AKL_ASSISTANT_PURGE_BATCH_SIZE=500
AKL_ASSISTANT_DELETION_AUDIT_RETENTION_DAYS=730
