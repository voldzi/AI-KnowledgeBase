COMPOSE_PROJECT_NAME=akl
AKL_SERVICE_VERSION=0.1.0

# Public routing is handled by the docker.home.cz reverse proxy.
AKL_PROXY_HTTP_PORT=8080
AKL_PROXY_CONTAINER_PORT=8080

# Dedicated Docker bridge subnets for AKL. Keep them outside site VLANs
# such as 192.168.1.0/24, 192.168.10.0/24 and 192.168.100.0/24.
AKL_PUBLIC_ZONE_SUBNET=10.246.240.0/24
AKL_APP_ZONE_SUBNET=10.246.241.0/24
AKL_DATA_ZONE_SUBNET=10.246.242.0/24
AKL_AI_COMPUTE_ZONE_SUBNET=10.246.243.0/24
AKL_MANAGEMENT_ZONE_SUBNET=10.246.244.0/24

# GitHub Packages read-only npmrc for @stratos/ui during Docker build.
AKL_NPMRC_SECRET_FILE=/srv/akl/secrets/npmrc

# Shared PostgreSQL entrypoint through HAProxy. Do not point applications at Patroni nodes directly.
AKL_REGISTRY_DATABASE_URL=postgresql+psycopg://akl_platform:replace-with-prod-password@haproxy.home.cz:5000/akl_registry
AKL_REGISTRY_AUTO_CREATE_SCHEMA=false

# Shared STRATOS Keycloak realm.
AKL_OIDC_ISSUER=https://login.zeleznalady.cz/realms/stratos
AKL_OIDC_AUDIENCE=akl-api
AKL_OIDC_JWKS_URL=https://login.zeleznalady.cz/realms/stratos/protocol/openid-connect/certs
AKL_WEB_OIDC_ISSUER=https://login.zeleznalady.cz/realms/stratos
AKL_WEB_OIDC_CLIENT_ID=akl-web
AKL_WEB_OIDC_CLIENT_SECRET=
AKL_WEB_OIDC_SCOPES="openid profile email"
AKL_WEB_PUBLIC_BASE_URL=https://stratos.zeleznalady.cz/akb
AKL_WEB_BASE_PATH=/akb
AKL_WEB_SESSION_SECRET=replace-with-long-random-session-secret

# Temporary filesystem bridge to the dedicated AKL SeaweedFS area.
# Replace with S3 adapter settings after AKL object storage provider support is enabled.
AKL_SEAWEEDFS_AKL_ROOT=/srv/seaweedfs/akl
AKL_WEB_UPLOAD_BUCKET=akl-documents
AKL_WEB_UPLOAD_SIGNING_SECRET=replace-with-prod-upload-signing-secret

# Retrieval profile.
AKL_QDRANT_COLLECTION=akl_document_chunks
AKL_QDRANT_VECTOR_SIZE=1024
AKL_QDRANT_DISTANCE=Cosine
AKL_INGESTION_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_INGESTION_SERVICE_ACCOUNT_ROLES=service_ingestion,document_manager
AKL_RAG_CHAT_MODEL=gemma4:12b
AKL_RAG_EMBEDDING_MODEL=bge-m3
AKL_RAG_SERVICE_ACCOUNT_ROLES=service_rag
AKL_RAG_AUTHZ_MODE=registry
AKL_EVAL_AUTH_MODE=bearer
AKL_EVAL_SERVICE_TOKEN=replace-with-prod-evaluation-service-token
AKL_GOVERNANCE_AUTH_MODE=bearer
AKL_GOVERNANCE_SERVICE_TOKEN=replace-with-prod-governance-service-token

# LLM provider. Keep model pull/delete disabled in production.
AKL_LLM_DEFAULT_PROVIDER=ollama
AKL_LLM_ENABLED_PROVIDERS=ollama
AKL_LLM_MODEL_PROVIDER_MAP={"gemma4:12b":"ollama","bge-m3":"ollama"}
AKL_LLM_DEFAULT_CHAT_MODEL=gemma4:12b
AKL_LLM_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_LLM_ALLOW_MODEL_PULL=false
AKL_LLM_ALLOW_MODEL_DELETE=false
AKL_OLLAMA_BASE_URL=http://host.docker.internal:11434
