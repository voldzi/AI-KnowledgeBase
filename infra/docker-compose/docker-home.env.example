COMPOSE_PROJECT_NAME=akl
AKL_SERVICE_VERSION=0.1.0
STRATOS_CONTENT_SECURITY_MODE=disabled
STRATOS_CONTENT_SECURITY_REQUIRED=false
STRATOS_CONTENT_SECURITY_ENDPOINT=
AKL_INGESTION_INDEXER_MODE=qdrant,opensearch
AKL_RAG_FULLTEXT_MODE=opensearch

# Copy this template outside Git to /srv/akl/env/akl.prod.env with mode 0600.
# Immutable releases always pass this file and the Compose project explicitly;
# do not link it into or deploy from the mutable /srv/akl/repo checkout.
# Values are literal: '$' Compose interpolation tokens are forbidden. Use
# approved generated secrets that satisfy this release-file constraint.
AKL_RELEASE_GIT_URL=https://github.com/voldzi/AI-KnowledgeBase.git
AKL_RELEASE_TRUSTED_REF=refs/remotes/origin/main
AKL_RELEASE_COMPOSE_PROJECT=akl
# Fail-closed connection and backend identity expected for Registry release
# gates. The database and user must match current_database()/current_user.
AKL_RELEASE_EXPECTED_REGISTRY_DB_HOST=haproxy.home.cz
AKL_RELEASE_EXPECTED_REGISTRY_DB_PORT=5000
AKL_RELEASE_EXPECTED_REGISTRY_DB_NAME=akl_registry
AKL_RELEASE_EXPECTED_REGISTRY_DB_USER=akl_platform
# Required content-addressed PostgreSQL client toolchain. Load this exact image
# before the change window; the release workflow never pulls a mutable tag and
# does not require psql/pg_dump/pg_restore packages on the host.
AKL_RELEASE_POSTGRES_TOOL_IMAGE=postgres:18-alpine@sha256:replace-with-64-lowercase-hex-digest
# Maximum graceful stop window used to quiesce the Registry DB writer.
AKL_RELEASE_REGISTRY_STOP_TIMEOUT_SECONDS=30

# Public routing is handled by the docker.home.cz reverse proxy.
AKL_PROXY_HTTP_PORT=8080
AKL_PROXY_CONTAINER_PORT=8080
WEB_UPSTREAM=akl-platform-web:3000
PLATFORM_READY_CHECKS=registry=http://registry-api:8000/health,qdrant=http://qdrant:6333/readyz,opensearch=http://opensearch:9200,web=http://akl-platform-web:3000/akb/health

# Dedicated Docker bridge subnets for AKL. Keep them outside site VLANs
# such as 192.168.1.0/24, 192.168.10.0/24 and 192.168.100.0/24.
AKL_PUBLIC_ZONE_SUBNET=10.246.240.0/24
AKL_APP_ZONE_SUBNET=10.246.241.0/24
AKL_DATA_ZONE_SUBNET=10.246.242.0/24
AKL_AI_COMPUTE_ZONE_SUBNET=10.246.243.0/24
AKL_MANAGEMENT_ZONE_SUBNET=10.246.244.0/24

# Shared PostgreSQL entrypoint through HAProxy. Do not point applications at
# Patroni nodes directly. Query strings/fragments are forbidden because driver
# connection parameters can override the verified host/database identity.
AKL_REGISTRY_DATABASE_URL=postgresql+psycopg://akl_platform:replace-with-prod-password@haproxy.home.cz:5000/akl_registry
AKL_REGISTRY_AUTO_CREATE_SCHEMA=false

# Shared STRATOS Keycloak realm.
AKL_OIDC_ISSUER=https://login.zeleznalady.cz/realms/stratos
AKL_OIDC_AUDIENCE=akl-api
AKL_REGISTRY_TRUSTED_SERVICE_CLIENT_IDS=akb-rag-service,aiip-document-service,svc-ingestion
AKL_REGISTRY_SERVICE_CLIENT_ROUTE_GRANTS=akb-rag-service=authz|audit|idempotency,aiip-document-service=aiip-upload,svc-ingestion=authz|audit|documents-read|ingestion-status
AKL_REGISTRY_SERVICE_CLIENT_DELEGATIONS=akb-rag-service=aiip-service
AKL_RAG_TRUSTED_SERVICE_CLIENT_IDS=aiip-service
AKL_RAG_AIIP_SERVICE_CLIENT_IDS=aiip-service
AKL_RAG_USER_OIDC_AUDIENCE=akl-api
AKL_RAG_AIIP_OIDC_AUDIENCE=akb-api
AKL_RAG_REGISTRY_TOKEN_URL=https://login.zeleznalady.cz/realms/stratos/protocol/openid-connect/token
AKL_RAG_REGISTRY_CLIENT_ID=akb-rag-service
AKL_RAG_REGISTRY_CLIENT_SECRET_FILE=/srv/akl/env/akb-rag-service.client-secret
AKL_INGESTION_REGISTRY_TOKEN_URL=https://login.zeleznalady.cz/realms/stratos/protocol/openid-connect/token
AKL_INGESTION_REGISTRY_CLIENT_ID=svc-ingestion
AKL_INGESTION_REGISTRY_CLIENT_SECRET_FILE=/srv/akl/env/svc-ingestion.client-secret
AKL_INGESTION_AUTHORIZATION_SECRET_FILE=/srv/akl/env/ingestion-authorization.secret
AKL_INGESTION_AUTHORIZATION_TTL_SECONDS=60
AKL_INGESTION_WEB_CLIENT_ID=svc-akb-web-ingestion
AKL_INGESTION_WEB_ROLE=service_akb_web_ingestion
AKL_OIDC_JWKS_URL=https://login.zeleznalady.cz/realms/stratos/protocol/openid-connect/certs
AKL_WEB_OIDC_ISSUER=https://login.zeleznalady.cz/realms/stratos
AKL_WEB_OIDC_CLIENT_ID=akl-web
AKL_WEB_OIDC_CLIENT_SECRET=
AKL_WEB_OIDC_SCOPES=openid profile email
AKL_WEB_PUBLIC_BASE_URL=https://stratos.zeleznalady.cz/akb
AKL_WEB_BASE_PATH=/akb
AKL_WEB_SESSION_SECRET=replace-with-long-random-session-secret
AKL_WEB_INGESTION_TOKEN_URL=https://login.zeleznalady.cz/realms/stratos/protocol/openid-connect/token
AKL_WEB_INGESTION_CLIENT_ID=svc-akb-web-ingestion
AKL_WEB_INGESTION_CLIENT_SECRET_FILE=/srv/akl/env/svc-akb-web-ingestion.client-secret
AKL_WEB_STRATOS_AUTH_ME_URL=https://stratos.zeleznalady.cz/api/v1/auth/me
AKL_WEB_STRATOS_ACCESS_TIMEOUT_MS=3000
AKL_WEB_STRATOS_ACCESS_CACHE_TTL_MS=0
AKL_CHAT_WEB_HTTP_PORT=3221
AKL_CHAT_WEB_PUBLIC_BASE_URL=https://chat.zeleznalady.cz
AKL_CHAT_WEB_OIDC_ISSUER=https://login.zeleznalady.cz/realms/stratos
AKL_CHAT_WEB_OIDC_CLIENT_ID=akb-chat-web
AKL_CHAT_WEB_OIDC_CLIENT_SECRET=
AKL_CHAT_WEB_OIDC_SCOPES=openid profile email
AKL_CHAT_WEB_SESSION_SECRET=replace-with-separate-long-random-session-secret
AKL_CHAT_WEB_STRATOS_AUTH_ME_URL=https://stratos.zeleznalady.cz/api/v1/auth/me
AKL_CHAT_WEB_STRATOS_ACCESS_TIMEOUT_MS=3000
AKL_CHAT_WEB_STRATOS_ACCESS_CACHE_TTL_MS=0
AKL_STRATOS_AUTH_ME_URL=https://stratos.zeleznalady.cz/api/v1/auth/me
AKL_STRATOS_POLICY_BINDINGS_URL=https://stratos.zeleznalady.cz/api/v1/policy/bindings
AKL_STRATOS_POLICY_DECISIONS_URL=https://stratos.zeleznalady.cz/api/v1/policy/decisions
AKL_STRATOS_SERVICE_POLICY_BINDING_ID=pol_akb_internal_source_v1
AKL_STRATOS_INFORMATION_RESOURCES_URL=https://stratos.zeleznalady.cz/api/v1/information/resources
AKL_STRATOS_AIIP_AKB_RESOURCES_URL=https://stratos.zeleznalady.cz/api/v1/integrations/aiip/akb/resources
AKL_STRATOS_INFORMATION_PUBLICATIONS_URL=https://stratos.zeleznalady.cz/api/v1/information/publications
AKL_STRATOS_PUBLIC_DECISIONS_URL=https://stratos.zeleznalady.cz/api/v1/policy/public-decisions
AKB_POLICY_SERVICE_TOKEN=
AKB_AIIP_INGEST_SERVICE_TOKEN=
AKL_PUBLIC_DELIVERY_INTERNAL_TOKEN=replace-with-shared-public-delivery-token-at-least-32-chars
AKL_PUBLIC_RATE_WINDOW_MS=60000
AKL_PUBLIC_RATE_PER_CLIENT_SLUG=30
AKL_PUBLIC_RATE_GLOBAL=600
AKL_PUBLIC_CONCURRENCY_PER_CLIENT=2
AKL_PUBLIC_CONCURRENCY_GLOBAL=24
AKL_PUBLIC_LIMITER_MAX_KEYS=10000
# Use 0 until every public ingress proxy is confirmed to sanitize X-Forwarded-For.
AKL_PUBLIC_TRUSTED_PROXY_HOPS=0
AKL_PUBLIC_CLIENT_KEY_SECRET=replace-with-separate-public-client-hmac-secret
AKL_PUBLIC_AUDIT_WINDOW_SECONDS=60
AKL_PUBLIC_AUDIT_RETENTION_DAYS=90
AKL_PUBLIC_AUDIT_PRUNE_INTERVAL_SECONDS=3600
AKL_REGISTRY_PUBLIC_RATE_WINDOW_MS=60000
AKL_REGISTRY_PUBLIC_RATE_PER_CLIENT_SLUG=600
AKL_REGISTRY_PUBLIC_RATE_GLOBAL=1200
AKL_REGISTRY_PUBLIC_CONCURRENCY_PER_CLIENT=32
AKL_REGISTRY_PUBLIC_CONCURRENCY_GLOBAL=64
AKL_REGISTRY_PUBLIC_LIMITER_MAX_KEYS=10000
AKL_REGISTRY_PUBLIC_TRUSTED_PROXY_HOPS=0
AKL_STRATOS_ACCESS_TIMEOUT_SECONDS=3
AKL_STRATOS_ACCESS_CACHE_TTL_SECONDS=0
# Optional override. By default signed source downloads use ${AKL_WEB_BASE_PATH}/api/documents/source/content.
# AKL_WEB_DOWNLOAD_PUBLIC_BASE_PATH=/akb/api/documents/source/content

# Temporary filesystem bridge to the dedicated AKL SeaweedFS area.
# Replace with S3 adapter settings after AKL object storage provider support is enabled.
AKL_SEAWEEDFS_AKL_ROOT=/srv/seaweedfs/akl
AKL_WEB_UPLOAD_BUCKET=akl-documents
AKL_WEB_UPLOAD_SIGNING_SECRET=replace-with-prod-upload-signing-secret

# Retrieval profile.
AKL_QDRANT_COLLECTION=akl_document_chunks
AKL_QDRANT_VECTOR_SIZE=1024
AKL_QDRANT_DISTANCE=Cosine
AKL_INGESTION_DEFAULT_EXTRACTION_PROFILE=document_text_v1
AKL_INGESTION_PDF_ENGINE=auto
AKL_INGESTION_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_INGESTION_DEFAULT_EMBEDDING_DIMENSIONS=
AKL_INGESTION_EMBEDDING_PROFILE_MODEL_MAP={}
AKL_INGESTION_EMBEDDING_PROFILE_DIMENSIONS_MAP={}
AKL_INGESTION_EMBEDDING_BATCH_SIZE=32
AKL_INGESTION_EMBEDDING_CONCURRENCY=1
AKL_INGESTION_SERVICE_ACCOUNT_ROLES=service_ingestion,document_manager
AKL_RAG_CHAT_MODEL=gemma4:12b-mlx
AKL_RAG_HIGH_QUALITY_CHAT_MODEL=gemma4:31b-mlx
AKL_RAG_HIGH_QUALITY_MIN_CONTEXT_CHUNKS=6
AKL_RAG_EMBEDDING_MODEL=bge-m3
AKL_RAG_EMBEDDING_DIMENSIONS=
AKL_RAG_SOURCE_CONTEXT_WINDOW=1
AKL_RAG_SERVICE_ACCOUNT_ROLES=service_rag
AKL_RAG_AUTHZ_MODE=registry
AKL_EVAL_AUTH_MODE=oidc
AKL_EVAL_SERVICE_TOKEN=replace-with-prod-evaluation-service-token
AKL_GOVERNANCE_AUTH_MODE=bearer
AKL_GOVERNANCE_SERVICE_TOKEN=replace-with-prod-governance-service-token

# LLM provider. Keep model pull/delete disabled in production.
AKL_LLM_AUTH_MODE=bearer
AKL_LLM_GATEWAY_SERVICE_TOKEN=replace-with-prod-llm-gateway-service-token
AKL_LLM_REQUIRE_CALLER_IDENTITY=true
AKL_LLM_GATEWAY_AUDIENCE=llm-gateway-service
AKL_LLM_GATEWAY_ALLOWED_CALLER_ROLES=service_ingestion,service_rag
AKL_LLM_DEFAULT_PROVIDER=ollama
AKL_LLM_ENABLED_PROVIDERS=ollama
AKL_LLM_MODEL_PROVIDER_MAP={"gemma4:12b-mlx":"ollama","gemma4:31b-mlx":"ollama","bge-m3":"ollama","qwen3-embedding:8b":"ollama"}
AKL_LLM_DEFAULT_CHAT_MODEL=gemma4:12b-mlx
AKL_LLM_CHAT_MODEL_FALLBACKS={"gemma4:31b-mlx":["gemma4:12b-mlx"]}
AKL_LLM_DEFAULT_EMBEDDING_MODEL=bge-m3
AKL_LLM_DEFAULT_EMBEDDING_DIMENSIONS=
AKL_LLM_ALLOW_MODEL_PULL=false
AKL_LLM_ALLOW_MODEL_DELETE=false
AKL_OLLAMA_BASE_URL=http://192.168.200.3:11434
# Ordered failover list. Keep this explicit; AKB must not scan the LAN.
AKL_OLLAMA_BASE_URLS=http://192.168.200.3:11434,http://192.168.200.2:11434,http://192.168.1.176:11434
AKL_OLLAMA_ENDPOINT_TIMEOUT_SECONDS=3

# Optional docker.home.cz observability override:
# docker compose -f infra/docker-compose/docker-compose.docker-home.yml \
#   -f infra/docker-compose/docker-compose.docker-home-observability.yml up -d
GRAFANA_ADMIN_USER=stratos_admin
GRAFANA_ADMIN_PASSWORD=replace-with-prod-grafana-password
GRAFANA_ROOT_URL=https://stratos.zeleznalady.cz/akb/grafana/
GRAFANA_OAUTH_ENABLED=false
GRAFANA_OAUTH_CLIENT_ID=akb-grafana
GRAFANA_OAUTH_CLIENT_SECRET=replace-with-keycloak-client-secret
GRAFANA_OAUTH_AUTH_URL=https://login.zeleznalady.cz/realms/stratos/protocol/openid-connect/auth
GRAFANA_OAUTH_TOKEN_URL=https://login.zeleznalady.cz/realms/stratos/protocol/openid-connect/token
GRAFANA_OAUTH_API_URL=https://login.zeleznalady.cz/realms/stratos/protocol/openid-connect/userinfo
OTEL_SDK_DISABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_PROPAGATORS=tracecontext,baggage
