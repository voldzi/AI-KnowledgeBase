{
  "realm": "stratos",
  "enabled": true,
  "displayName": "STRATOS",
  "displayNameHtml": "STRATOS",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "external",
  "internationalizationEnabled": true,
  "supportedLocales": [
    "cs",
    "en"
  ],
  "defaultLocale": "cs",
  "loginTheme": "stratos",
  "roles": {
    "realm": [
      {
        "name": "service_evaluation",
        "description": "AKB canonical evaluation service role consumed by AKB Registry API."
      },
      {
        "name": "service_governance",
        "description": "AKB canonical governance service role consumed by AKB Registry API."
      },
      {
        "name": "service_ingestion",
        "description": "AKB canonical ingestion service role consumed by AKB Registry API."
      },
      {
        "name": "service_akb_web_ingestion",
        "description": "Dedicated AKB web-to-ingestion transport role; no Registry grants."
      },
      {
        "name": "service_aiip",
        "description": "AKB application service role for AI Innovation Portal."
      },
      {
        "name": "service_aiip_document",
        "description": "Dedicated AIIP document transport role; restricted to the governed AKB upload bridge."
      },
      {
        "name": "service_llm_gateway",
        "description": "AKB canonical LLM Gateway service role consumed by AKB Registry API."
      },
      {
        "name": "service_rag",
        "description": "AKB canonical RAG service role consumed by AKB Registry API."
      },
      {
        "name": "stratos_admin",
        "description": "STRATOS platform administrator; domain access remains in Access Center."
      },
      {
        "name": "stratos_user",
        "description": "Standard authenticated STRATOS user."
      }
    ]
  },
  "clients": [
    {
      "clientId": "akl-api",
      "name": "AKL API Services",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "akl-web",
      "name": "AKB Web Frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://stratos.zeleznalady.cz/akb/*",
        "https://akl.zeleznalady.cz/*",
        "https://docker.home.cz/*",
        "http://localhost:3000/*",
        "http://localhost:3002/*",
        "http://localhost:3003/*"
      ],
      "webOrigins": [
        "https://stratos.zeleznalady.cz",
        "https://akl.zeleznalady.cz",
        "https://docker.home.cz",
        "+"
      ],
      "protocolMappers": [
        {
          "name": "akl-api audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "akl-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "akb-chat-web",
      "name": "AKB Standalone Chat PWA",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://chat.zeleznalady.cz/api/auth/callback"
      ],
      "webOrigins": [
        "https://chat.zeleznalady.cz"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://chat.zeleznalady.cz/*",
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "akl-api audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "akl-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "archflow-api",
      "name": "ARCHFLOW API Services",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
