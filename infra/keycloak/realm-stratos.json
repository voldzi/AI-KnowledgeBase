{
  "realm": "stratos",
  "enabled": true,
  "displayName": "STRATOS",
  "displayNameHtml": "STRATOS",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "external",
  "internationalizationEnabled": true,
  "supportedLocales": [
    "cs",
    "en"
  ],
  "defaultLocale": "cs",
  "loginTheme": "stratos",
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "AKL canonical admin role consumed by AKL Registry API."
      },
      {
        "name": "akl_admin",
        "description": "Full AKL administration in STRATOS."
      },
      {
        "name": "akl_auditor",
