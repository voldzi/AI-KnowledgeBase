      },
      {
        "name": "akl_service_llm_gateway",
        "description": "Service role for AKL LLM Gateway."
      },
      {
        "name": "akl_service_rag",
        "description": "Service role for AKL RAG retrieval."
      },
      {
        "name": "akl_stratos_service",
        "description": "Service role for STRATOS server adapters calling AKL."
      },
      {
        "name": "archflow_admin",
        "description": "ARCHFLOW administration."
      },
      {
        "name": "archflow_architect",
        "description": "ARCHFLOW architecture workspace author."
      },
      {
        "name": "archflow_reader",
        "description": "ARCHFLOW read access."
      },
      {
        "name": "auditor",
        "description": "AKL canonical auditor role consumed by AKL Registry API."
      },
      {
        "name": "budget_admin",
        "description": "Budget & Contract administration."
      },
      {
        "name": "budget_contract_manager",
