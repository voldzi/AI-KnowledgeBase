      {
        "name": "budget_reader",
        "description": "Budget & Contract read access."
      },
      {
        "name": "document_manager",
        "description": "AKL canonical document manager role consumed by AKL Registry API."
      },
      {
        "name": "document_owner",
        "description": "AKL canonical document owner role consumed by AKL Registry API."
      },
      {
        "name": "projectflow_admin",
        "description": "ProjectFlow administration."
      },
      {
        "name": "projectflow_manager",
        "description": "ProjectFlow portfolio and team management."
      },
      {
        "name": "projectflow_member",
        "description": "ProjectFlow project team member."
      },
      {
        "name": "projectflow_reader",
        "description": "ProjectFlow read access."
      },
      {
        "name": "reader",
        "description": "AKL canonical reader role consumed by AKL Registry API."
      },
      {
        "name": "reviewer",
        "description": "AKL canonical reviewer role consumed by AKL Registry API."
      },
      {
        "name": "service_evaluation",
        "description": "AKL canonical evaluation service role consumed by AKL Registry API."
      },
      {
        "name": "service_governance",
        "description": "AKL canonical governance service role consumed by AKL Registry API."
      },
      {
        "name": "service_ingestion",
        "description": "AKL canonical ingestion service role consumed by AKL Registry API."
      },
      {
        "name": "service_llm_gateway",
        "description": "AKL canonical LLM Gateway service role consumed by AKL Registry API."
      },
      {
        "name": "service_rag",
        "description": "AKL canonical RAG service role consumed by AKL Registry API."
      },
      {
        "name": "stratos_admin",
        "description": "Full administration across STRATOS applications."
      },
      {
        "name": "stratos_auditor",
        "description": "Cross-application audit and compliance viewer."
      },
      {
        "name": "stratos_service",
        "description": "AKL canonical service bridge role consumed by AKL Registry API."
      },
      {
        "name": "stratos_user",
        "description": "Standard authenticated STRATOS user."
      }
    ]
